meta {
  name: Listar admins
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/admins-autorizados
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

vars:pre-request {
  baseUrl: http://localhost:8080/api/v1
}

docs {
  PROTEGIDO (JWT). Retorna a lista de todos os e-mails na allowlist de administradores.
}
