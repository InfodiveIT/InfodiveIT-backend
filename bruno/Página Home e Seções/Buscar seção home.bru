meta {
  name: Buscar seção home
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/secoes-home/solucoes
  body: none
  auth: none
}

vars:pre-request {
  baseUrl: http://localhost:8080/api/v1
}

docs {
  PÚBLICO. Retorna as configurações de texto/conteúdo de uma seção específica da home.
  Opções de seções: `solucoes`, `produtos`, `cases`, `blog`, `trust`.
}
