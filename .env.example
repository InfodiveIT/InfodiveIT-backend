# Configuração do Banco de Dados e Segurança para Infodive API
# Renomeie este arquivo para .env e preencha com as suas credenciais locais

# Supabase PostgreSQL Database (Connection Pooler ou direto: port 5432 / 6543)
DB_URL=jdbc:postgresql://db.<seu-projeto-ref>.supabase.co:5432/postgres?sslmode=require
DB_USER=postgres
DB_PASSWORD=sua_senha_do_banco_supabase

# Supabase Storage (Upload de imagens)
SUPABASE_URL=https://<seu-projeto-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_ou_anon_key
SUPABASE_STORAGE_BUCKET=images

JWT_SECRET=sua_chave_secreta_jwt_para_assinatura_de_tokens
ALLOWED_ORIGINS=http://localhost:3000

